{
  "manifest_version": 3,
  "name": "EasyCashBack Finder",
  "version": "1.0",
  "description": "Vindt automatisch cashback op basis van je banktransacties.",
  "permissions": ["notifications", "alarms"],
  "host_permissions": ["https://*.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
