{
  "manifest_version": 3,
  "name": "EasyCashBack Assistant",
  "version": "1.0",
  "description": "Ontvang automatisch meldingen voor cashbacks!",
  "permissions": ["tabs", "notifications"],
  "host_permissions": ["https://*.render.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "EasyCashBack"
  }
}
